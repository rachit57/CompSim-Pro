{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --prefix server",
    "watchPatterns": ["server/**", "railway.json", "Procfile", "package.json"]
  },
  "deploy": {
    "startCommand": "npm start --prefix server",
    "numReplicas": 1,
    "sleepService": false,
    "healthCheckPath": "/",
    "healthCheckTimeout": 120
  }
}
