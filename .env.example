# --- BACKEND (Railway) ---
# The URL of your Redis instance (e.g. from Upstash or Railway Redis)
REDIS_URL=rediss://default:your_password@your_host:your_port

# The URL of your deployed frontend (e.g. https://your-app.vercel.app)
# Required for CORS security
FRONTEND_URL=http://localhost:3000

# Port for the Socket.IO server (Railway sets this automatically)
PORT=4000

# --- FRONTEND (Vercel) ---
# The URL of your deployed backend (e.g. https://your-server.up.railway.app)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
